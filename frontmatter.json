{
  "$schema": "https://frontmatter.codes/frontmatter.schema.json",
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.publicFolder": "public",
  "frontMatter.content.pageFolders": [
    {
      "title": "文章",
      "path": "[[workspace]]/src/content/posts"
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "default",
      "pageBundle": false,
      "previewPath": null,
      "filePrefix": "",
      "template": "[[workspace]]/.frontmatter/templates/模板.md",
      "fields": [
        {
          "title": "标题 title",
          "name": "title",
          "type": "string"
        },
        {
          "title": "简介 description",
          "name": "description",
          "type": "string",
          "required": false
        },
        {
          "title": "发布时间 published",
          "name": "published",
          "type": "datetime",
          "default": "{{now}}",
          "dateFormat": "YYYY-MM-DDTHH:mm:ss",
          "isPublishDate": true
        },
        {
          "title": "封面图 image",
          "name": "image",
          "type": "image"
        },
        {
          "title": "置顶 pinned",
          "name": "pinned",
          "type": "boolean",
          "default": false
        },
        {
          "title": "标签 tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "单分类 category",
          "name": "category",
          "type": "select",
          "options": [
            "RPG",
            "SLG",
            "ACT",
            "ADV",
            "ARPG"
          ]
        },
        {
          "title": "草稿 draft",
          "name": "draft",
          "type": "boolean",
          "default": false
        }
      ]
    }
  ]
}